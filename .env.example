# Copia este archivo a .env y rellena los valores. NO subas el .env real.

# App
PORT=3000
NODE_ENV=development
PAGINATION_LIMIT=20

# DNS (opcional): solo si ves 'querySrv ECONNREFUSED' al conectar a mongodb+srv.
# En local se aplica 8.8.8.8/1.1.1.1 automaticamente cuando NODE_ENV != production.
# En produccion normalmente NO se necesita; definelo solo si tu entorno lo requiere.
# DNS_SERVERS=8.8.8.8,1.1.1.1

# JWT (usar cadenas aleatorias largas en produccion)
# Generar: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=45m
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRES_IN=1d

# Cookies (cadena aleatoria larga)
COOKIE_SECRET=

# Mongo Database
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority

# PostgreSQL (opcional, actualmente deshabilitado)
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=
# DB_DATABASE=loans_db
